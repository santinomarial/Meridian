{
  "name": "meridian-server",
  "version": "0.1.0",
  "description": "Meridian collaborative IDE backend",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "test": "jest",
    "test:integration": "jest --config ./test/jest-integration.json --runInBand",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "postinstall": "node scripts/fix-node-pty-helper.cjs"
  },
  "dependencies": {
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11",
    "@nestjs/platform-socket.io": "^11",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "ioredis": "^5.11.0",
    "jszip": "^3.10.1",
    "nestjs-pino": "^4.6.1",
    "node-pty": "^1.1.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "socket.io": "^4",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@nestjs/testing": "^11",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "*",
    "@types/node": "^22",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29",
    "jest-mock-extended": "^4.0.1",
    "prisma": "^5.22.0",
    "source-map-support": "*",
    "supertest": "^7.2.2",
    "ts-jest": "^29",
    "ts-loader": "*",
    "tsconfig-paths": "*",
    "tsx": "^4.22.4",
    "typescript": "^5.7"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
