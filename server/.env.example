NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meridian?schema=public"
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
LOG_LEVEL=info
DOC_TEARDOWN_GRACE_MS=30000
SNAPSHOT_EVERY_N_UPDATES=100
HTTP_TTL_SECONDS=60
HTTP_LIMIT=120
AUTH_TTL_SECONDS=60
AUTH_LIMIT=10
WS_MESSAGE_LIMIT_PER_SECOND=50
WS_MAX_YJS_UPDATE_BYTES=1048576

# Automated-test helpers and relaxed limits. This setting is rejected when
# NODE_ENV=production and should remain false outside dedicated test runs.
E2E_TEST=false

# ── Terminal ──────────────────────────────────────────────────────────────────
# Set to true to enable the integrated terminal feature.
# Disabled by default for security. Never enable in production without hardening.
# Run with: ENABLE_TERMINAL=true npm run start:dev
ENABLE_TERMINAL=false

# ── Redis multi-replica ───────────────────────────────────────────────────────
# When true, GET /ready returns 503 unless Redis is reachable (use for
# multi-replica collaborative fleets). Single-replica can leave false.
REDIS_REQUIRED=false
# Prefix every Redis key and pub/sub channel (e.g. prod → prod:). Required when
# sharing a Redis deployment across environments.
REDIS_KEY_PREFIX=

# Prometheus scrape endpoint GET /metrics (disable to return 404).
METRICS_ENABLED=true

# When behind a reverse proxy, set to true or a hop count so throttling keys
# use the real client IP (X-Forwarded-For).
TRUST_PROXY=false

# ── Password reset / mail ──────────────────────────────────────────────────────
# Resend (https://resend.com) is required to deliver real emails to other people.
#
# IMPORTANT: MAIL_FROM=...@resend.dev can ONLY send to YOUR Resend account email.
# To invite colleagues you must:
#   1. Create an API key at https://resend.com/api-keys (starts with re_)
#   2. Add + verify your domain at https://resend.com/domains (DNS records)
#   3. Set MAIL_FROM to an address on that domain, e.g. Meridian <invites@yourdomain.com>
#   4. Restart the Nest server
#
# Without RESEND_API_KEY in development, Meridian does not send email: the
# forgot-password UI shows a clickable reset link instead, and the server logs
# the URL. An empty RESEND_API_KEY= is treated as unset.
RESEND_API_KEY=
MAIL_FROM=Meridian <invites@your-verified-domain.com>
# How long a password reset link remains valid (minutes).
FORGOT_PASSWORD_TTL_MINUTES=30
