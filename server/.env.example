NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meridian?schema=public"
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
LOG_LEVEL=info
DOC_TEARDOWN_GRACE_MS=30000
SNAPSHOT_EVERY_N_UPDATES=100
HTTP_TTL_SECONDS=60
HTTP_LIMIT=120
AUTH_TTL_SECONDS=60
AUTH_LIMIT=10
WS_MESSAGE_LIMIT_PER_SECOND=50
WS_MAX_YJS_UPDATE_BYTES=1048576

# ── Password reset / mail ──────────────────────────────────────────────────────
# Resend (https://resend.com) is the supported email provider.
# In development, if RESEND_API_KEY is not set the reset URL is logged to the
# server console instead of emailed (look for "DEV RESET URL").
# In production, RESEND_API_KEY must be set or the server logs an error and the
# user sees no failure (user existence is never revealed).
RESEND_API_KEY=
MAIL_FROM=Meridian <no-reply@meridian.local>
# How long a password reset link remains valid (minutes).
FORGOT_PASSWORD_TTL_MINUTES=30
