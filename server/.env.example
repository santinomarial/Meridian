NODE_ENV=development
PORT=3000
CLIENT_ORIGIN=http://localhost:5173
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meridian?schema=public"
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
LOG_LEVEL=info
DOC_TEARDOWN_GRACE_MS=30000
SNAPSHOT_EVERY_N_UPDATES=100
HTTP_TTL_SECONDS=60
HTTP_LIMIT=120
AUTH_TTL_SECONDS=60
AUTH_LIMIT=10
WS_MESSAGE_LIMIT_PER_SECOND=50
WS_MAX_YJS_UPDATE_BYTES=1048576
