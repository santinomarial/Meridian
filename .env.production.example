# Copy to `.env` next to docker-compose.prod.yml on the VPS (never commit real secrets).
# Generate secrets before go-live — do not reuse laptop / staging values.
#
#   openssl rand -base64 48   # JWT_SECRET
#   openssl rand -base64 32   # POSTGRES_PASSWORD

# ── Public hostname (required for Caddy Let’s Encrypt) ────────────────────────
DOMAIN=app.example.com
# Optional contact for ACME / Let’s Encrypt expiry notices
ACME_EMAIL=ops@example.com

# Must match the public HTTPS origin users open in the browser
CLIENT_ORIGIN=https://app.example.com

# ── Secrets (required) ────────────────────────────────────────────────────────
JWT_SECRET=
POSTGRES_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Unique prefix for this environment (avoid collisions if Redis is shared)
REDIS_KEY_PREFIX=prod:

# ── SPA build (same-origin via Caddy — leave empty) ───────────────────────────
# Empty → client uses window.location.origin at runtime.
# Only set these if the API is on a different public origin.
VITE_API_URL=
VITE_SOCKET_URL=
# CSP defaults to connect-src 'self'. For a split API origin, set EXTRA
# (include the leading space), e.g.:
# CSP_CONNECT_SRC_EXTRA= https://api.example.com wss://api.example.com
CSP_CONNECT_SRC_EXTRA=

# ── Optional mail (invite / password-reset delivery) ──────────────────────────
# Until a domain is verified at https://resend.com/domains, use copy-link invites.
# RESEND_API_KEY=
# MAIL_FROM=Meridian <invites@your-verified-domain.com>

# Terminal stays off in production (compose also forces ENABLE_TERMINAL=false)
